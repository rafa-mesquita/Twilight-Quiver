    {
      "id": "2rdKiEL2_Kl8FwzALXzch",
      "type": "text",
      "x": -2.4132159948186427,
      "y": 355.270908853553,
      "width": 166.2400244509538,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
