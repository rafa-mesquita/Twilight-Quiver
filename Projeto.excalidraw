    {
      "id": "BFPiMXZpIzYkBOBOJra8Y",
      "type": "text",
      "x": -611.3277355793357,
      "y": 355.270908853553,
      "width": 166.2400244509538,
      "height": 280,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
